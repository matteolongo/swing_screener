# Copy this file to .env and fill in your own values.
# .env is gitignored; .env.example is tracked as documentation.

# ---------------------------------------------------------------------------
# Broker / execution
# ---------------------------------------------------------------------------
SWING_SCREENER_EXECUTION_PROVIDER=alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# ---------------------------------------------------------------------------
# LLM — required for the intelligence / catalyst pipeline
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# ---------------------------------------------------------------------------
# OpenFIGI — instrument enrichment (FIGI identifiers, canonical issuer names)
#
# Leave both unset to disable (default). The instrument_master.json seed file
# covers the initial 12-instrument universe without OpenFIGI.
#
# Enable one of the two ways:
#   Option A — explicit flag (uses anonymous rate limits: 25 req/min)
#   Option B — provide an API key (250 req/min; register free at openfigi.com)
#
# For universes > 25 symbols, Option B is strongly recommended to avoid 429s
# on the first run before the local cache is warm.
# ---------------------------------------------------------------------------
# SWING_SCREENER_OPENFIGI_ENABLED=true
# OPENFIGI_API_KEY=your_openfigi_api_key

# ---------------------------------------------------------------------------
# DeGiro — portfolio sync and capability audit (optional)
#
# All five vars are required when the DeGiro integration is active.
# Install the optional dependency first: pip install -e ".[degiro]"
#
# TOTP auth (recommended): set DEGIRO_TOTP_SECRET_KEY (base32 seed from 2FA setup)
# One-time password fallback: set DEGIRO_ONE_TIME_PASSWORD instead
# ---------------------------------------------------------------------------
# DEGIRO_USERNAME=your_degiro_username
# DEGIRO_PASSWORD=your_degiro_password
# DEGIRO_INT_ACCOUNT=123456789
# DEGIRO_TOTP_SECRET_KEY=BASE32SECRETHERE
# DEGIRO_ONE_TIME_PASSWORD=

# ---------------------------------------------------------------------------
# LangSmith tracing — optional, for debugging LLM calls
# ---------------------------------------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=swing-screener
