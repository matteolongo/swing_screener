{
  "name": "swing-screener",
  "description": "Swing Screener single-app deployment (FastAPI + static web UI)",
  "stack": "heroku-24",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "heroku/python"
    }
  ],
  "env": {
    "SERVE_WEB_UI": {
      "value": "1"
    },
    "SCREENER_RUN_MODE": {
      "value": "async"
    },
    "WEB_CONCURRENCY": {
      "value": "1"
    }
  }
}
